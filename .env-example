# Database Configuration
# Format for PostgreSQL: postgresql://username:password@localhost:5432/dbname
# Format for Docker/SQLite: sqlite:////app/data/marketplaces.db
DATABASE_URL=sqlite:////app/data/marketplaces.db

# Global Parameters
SCRAPER_THREADS=2

# ─── iCopify Login Credentials ───
ICOPIFY_EMAIL="your_icopify_email@domain.com"
ICOPIFY_PASSWORD="your_icopify_password"

# ─── Posticy Login Credentials ───
POSTICY_EMAIL="your_posticy_email@domain.com"
POSTICY_PASSWORD="your_posticy_password"

# ─── Publisuites Login Credentials ───
PUBLISUITES_EMAIL="your_publisuites_email@domain.com"
PUBLISUITES_PASSWORD="your_publisuites_password"
